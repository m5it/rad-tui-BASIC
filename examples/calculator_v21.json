  "code": "current_value = 0\nstored_value = 0\noperation = ''\nnew_number = True\nmemory = 0\n\ndef on_load_frmMain():\n    global current_value, stored_value, operation, new_number, memory\n    current_value = 0\n    stored_value = 0\n    operation = ''\n    new_number = True\n    memory = 0\n    txtDisplay.caption = '0'\n    lblMem.caption = ''\n\ndef append_digit(digit):\n    global new_number\n    if new_number:\n        txtDisplay.caption = digit\n        new_number = False\n    else:\n        if txtDisplay.caption == '0':\n            txtDisplay.caption = digit\n        else:\n            txtDisplay.caption = txtDisplay.caption + digit\n\ndef set_operation(op):\n    global stored_value, operation, new_number\n    try:\n        stored_value = float(txtDisplay.caption)\n        operation = op\n        new_number = True\n    except:\n        pass\n\ndef calculate():\n    global stored_value, operation, new_number\n    try:\n        current = float(txtDisplay.caption)\n        result = 0\n        \n        if operation == '+':\n            result = stored_value + current\n        elif operation == '-':\n            result = stored_value - current\n        elif operation == '*':\n            result = stored_value * current\n        elif operation == '/':\n            if current != 0:\n                result = stored_value / current\n            else:\n                txtDisplay.caption = 'Error'\n                new_number = True\n                return\n        else:\n            result = current\n        \n        # Format result\n        if result == int(result):\n            txtDisplay.caption = str(int(result))\n        else:\n            txtDisplay.caption = format_number(result, 6)\n        \n        new_number = True\n        operation = ''\n    except:\n        txtDisplay.caption = 'Error'\n        new_number = True\n\ndef on_menu_mnuCopy():\n    clipboard_set(txtDisplay.caption)\n\ndef on_menu_mnuPaste():\n    text = clipboard_get()\n    try:\n        float(text)\n        txtDisplay.caption = text\n        new_number = True\n    except:\n        pass\n\ndef on_menu_mnuClearMem():\n    global memory\n    memory = 0\n    lblMem.caption = ''\n"
